# App
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
NODE_ENV=development

# Supabase (CRECO has its own project — do not share with the residential site)
NEXT_PUBLIC_SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Database connection for Payload CMS / Drizzle (Session Pooler, port 5432)
# Get from: Supabase Dashboard > Project Settings > Connect > Session Pooler
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# Payload CMS
PAYLOAD_SECRET=your-super-secret-key-change-this-in-production

# Vercel Blob Storage (property photos)
BLOB_READ_WRITE_TOKEN=

# Email (Resend) — used for tenant inquiry & contact form notifications
RESEND_API_KEY=re_xxxxxxxxxxxxx
LEAD_NOTIFICATION_EMAIL=leads@crecotx.com

# reCAPTCHA v3 (spam protection on inquiry forms)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# CRM Webhook (optional — pipe inquiries into your existing CRM)
CRM_WEBHOOK_URL=

# Analytics
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
